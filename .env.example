# ── WebSocket del simulatore (o del sistema reale) ────────────────────────────
WS_URL=ws://localhost:8081

# ── Porta REST del bridge ──────────────────────────────────────────────────────
PORT=3000

# ── API Key (deve coincidere con quella nella Lambda) ─────────────────────────
# ⚠  Cambia questo valore prima di andare in produzione!
API_KEY=ZIK_SECRET_2026

# ── Timeout risposta WebSocket (ms) ───────────────────────────────────────────
WS_TIMEOUT_MS=3000

# ── Frequenza refresh stato (ms) ──────────────────────────────────────────────
STATE_REFRESH_MS=5000
